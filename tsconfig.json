{
 "extends": "expo/tsconfig.base",
 "compilerOptions": {
 "strict": true,
 "module": "ESNext",
 "target": "ES2020",
 "lib": ["ES2020", "DOM"],
 "jsx": "react-jsx",
 "esModuleInterop": true,
 "allowSyntheticDefaultImports": true,
 "skipLibCheck": true,
 "moduleResolution": "bundler",
 "forceConsistentCasingInFileNames": true,
 "types": [],
 "paths": {
 "@/*": [
 "./*"
 ]
 }
 },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}