# Vercel Ignore

# Ignore local development artifacts
node_modules
.expo/
.idea/
.vscode/

# Ignore other platform builds and caches
android/
ios/
dist-android/
dist-ios/

# Ignore secrets and environment files
.env
*.pem
*.p12
secrets.js

# Ignore logs and temporary files
*.log
npm-debug.log
yarn-debug.log
yarn-error.log

# Ignore backend-specific files not needed for frontend build
server.js
backend/
render.yaml
*.sh
*.bat

