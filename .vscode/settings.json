{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  
  // Performance Optimizations
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/.expo/**": true,
    "**/coverage/**": true,
    "**/.nyc_output/**": true
  },
  
  // Reduce file watching and TypeScript overhead
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.suggest.autoImports": false,
  "javascript.suggest.autoImports": false,
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "typescript.suggest.includeCompletionsWithSnippetText": false,
  
  // Disable heavy visual features
  "editor.codeLens": false,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "breadcrumbs.enabled": false,
  
  // Limit search performance impact
  "search.followSymlinks": false,
  "search.smartCase": true,
  "search.maxResults": 1000,
  
  // Extensions performance
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  
  // Git performance optimizations
  "git.decorations.enabled": false,
  "git.autorefresh": false,
  
  // Memory management
  "files.hotExit": "off",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  
  // Reduce background processing
  "emmet.showExpandedAbbreviation": "never",
  "outline.collapseItems": "alwaysCollapse",
  "editor.guides.indentation": false,
  
  // Additional performance optimizations to prevent hanging
  "workbench.editor.limit": 3,
  "workbench.editor.closeEmptyGroups": true,
  "workbench.startupEditor": "none",
  "telemetry.telemetryLevel": "off",
  "update.mode": "none",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  
  // Network and language server optimizations
  "typescript.updateImportsOnFileMove.enabled": "never",
  "javascript.updateImportsOnFileMove.enabled": "never",
  "editor.hover.delay": 1500,
  "editor.quickSuggestionsDelay": 500,
  
  // Disable expensive features during development
  "editor.wordBasedSuggestions": "off",
  "editor.suggest.showStatusBar": false,
  "problems.decorations.enabled": false,
  "typescript.referencesCodeLens.enabled": false,
  "typescript.implementationsCodeLens.enabled": false
}
