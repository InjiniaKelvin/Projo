echo "📝 Header written..."

# Function to extract content from a file, removing annotations
clean_annotations() {
    local file=$1
    # Remove annotation comments like // 🔹 Added: or // 🔸 Revised:
    sed 's/\/\/ 🔹 Added:.*$//' "$file" | \
    sed 's/\/\/ 🔸 Revised:.*$//' | \
    sed 's/\/\/ 🔹.*$//' | \
    sed 's/\/\/ 🔸.*$//'
}

# Extract and append Part 1 (if exists - may need to be created separately)
if [ -f "QUICKFIX_PROJECT_DOCUMENTATION.md" ]; then
    echo "📄 Processing Part 1: Foundation & Architecture..."
    echo -e "\n\n---\n\n# PART 1: FOUNDATION & ARCHITECTURE\n\n" >> "$OUTPUT_FILE"
    tail -n +10 "QUICKFIX_PROJECT_DOCUMENTATION.md" | clean_annotations >> "$OUTPUT_FILE"
fi

# Extract and append Part 2
if [ -f "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART2.md" ]; then
    echo "📄 Processing Part 2: Implementation Details..."
    echo -e "\n\n---\n\n# PART 2: IMPLEMENTATION DETAILS\n\n" >> "$OUTPUT_FILE"
    tail -n +10 "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART2.md" | clean_annotations >> "$OUTPUT_FILE"
fi

# Extract and append Part 3
if [ -f "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART3.md" ]; then
    echo "📄 Processing Part 3: Database & API (3,217 lines)..."
    echo -e "\n\n---\n\n# PART 3: DATABASE & API\n\n" >> "$OUTPUT_FILE"
    tail -n +10 "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART3.md" | clean_annotations >> "$OUTPUT_FILE"
fi

# Extract and append Part 4
if [ -f "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART4.md" ]; then
    echo "📄 Processing Part 4: Operations & Maintenance..."
    echo -e "\n\n---\n\n# PART 4: OPERATIONS & MAINTENANCE\n\n" >> "$OUTPUT_FILE"
    tail -n +10 "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART4.md" | clean_annotations >> "$OUTPUT_FILE"
fi

# Extract and append Part 5
if [ -f "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART5.md" ]; then
    echo "📄 Processing Part 5: Strategic Synthesis..."
    echo -e "\n\n---\n\n# PART 5: STRATEGIC SYNTHESIS\n\n" >> "$OUTPUT_FILE"
    tail -n +10 "QUICKFIX_DOCUMENTATION_ANNOTATED_DRAFT_PART5.md" | clean_annotations >> "$OUTPUT_FILE"
fi

# Add footer
cat >> "$OUTPUT_FILE" << 'FOOTER'

