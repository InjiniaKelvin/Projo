# QuickFix Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Production API URL (Vercel Deployment)
EXPO_PUBLIC_API_URL=https://quickfix-api-sigma.vercel.app
API_URL=https://quickfix-api-sigma.vercel.app

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/quickfix

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here

# IntaSend Payment Gateway Configuration
INTASEND_PUBLISHABLE_KEY=ISPubKey_live_xxx
INTASEND_SECRET_KEY=ISSecretKey_live_xxx
INTASEND_ENV=live
INTASEND_CALLBACK_URL=https://quickfix-api-sigma.vercel.app/api/payments/intasend/callback

# Allowed Origins for CORS
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,https://quickfix-api-sigma.vercel.app
